NODE_ENV=production
PORT=4300

# Use managed PostgreSQL in production when available.
DATABASE_URL=postgresql://postgres:change_me@postgres:5432/skillfo
DB_SSL=false

ACCESS_TOKEN_SECRET=replace_with_a_random_string_at_least_32_chars_long
ACCESS_TOKEN_TTL=2h
REFRESH_TOKEN_TTL_DAYS=30
BCRYPT_SALT_ROUNDS=10

CORS_ORIGINS=https://skillfo.example.com
TRUST_PROXY=true

